generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum TransactionType {
  IMPORT
  EXPORT
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
  MANAGER
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  COD
  MOMO
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// --- MODELS ---

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      Role      @default(USER)
  
  // Link to customer profile for storefront users
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id])

  orders    Order[]   // Staff who created the order
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


model Category {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "Engine", "Brakes", "Plastics"
  description String?
  parts       Part[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model Vehicle {
  id          String   @id @default(uuid())
  modelName   String   // e.g., "Air Blade", "Wave Alpha"
  year        Int      // e.g., 2022
  engineSize  String?  // e.g., "125cc", "110cc"
  
  // Implicit Many-to-Many relation with Part
  parts       Part[]   
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Ensures we don't have duplicate vehicle profiles
  @@unique([modelName, year, engineSize])
  @@index([modelName, year])
}

model Part {
  id            String   @id @default(uuid())
  partNumber    String   @unique // Official Honda Part Number (SKU)
  name          String   // e.g., "Spark Plug CPR9EA-9"
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  stockQuantity Int      @default(0)
  minStockLevel Int      @default(5) // Threshold for low-stock alerts
  barcode       String?  @unique     // For quick scanning at the counter
  imageUrl      String?  // Thumbnail image URL

  // One-to-Many relation: A category has many parts
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])

  // Many-to-Many relation: A part fits many vehicles, a vehicle has many parts
  vehicles      Vehicle[] 
  
  // One-to-Many relation: A part has many inventory transactions
  transactions  InventoryTransaction[]

  // Items in orders and carts
  orderItems    OrderItem[]
  cartItems     CartItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([partNumber])
  @@index([name])
}

model InventoryTransaction {
  id            String          @id @default(uuid())
  type          TransactionType
  quantity      Int             // e.g., 50 (Import) or 2 (Export)
  notes         String?         // e.g., "Restock from Honda VN", "Retail sale"

  // Relation to Part
  partId        String
  part          Part            @relation(fields: [partId], references: [id])

  // Acts as a ledger, so we only need to know when it happened
  createdAt     DateTime        @default(now()) 
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  address   String?
  
  // Identity link
  user      User?
  
  // Shopping activity
  cart      Cart?
  orders    Order[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cart {
  id          String     @id @default(uuid())
  customerId  String     @unique
  customer    Customer   @relation(fields: [customerId], references: [id])
  
  items       CartItem[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  quantity  Int
  
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  partId    String
  part      Part     @relation(fields: [partId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, partId]) // Prevent duplicate parts in the same cart
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(12, 2)
  notes       String?
  
  paymentMethod   PaymentMethod @default(COD)
  paymentStatus   PaymentStatus @default(PENDING)

  // Link to the buyer profile
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])

  // Optional: Staff who handled the order
  staffId     String?
  staff       User?       @relation(fields: [staffId], references: [id])

  items       OrderItem[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])

  partId    String
  part      Part    @relation(fields: [partId], references: [id])
}